# ─────────────────────────────────────────────────────────────────
# .env.example — copy this file to .env and fill in your values
#
# NEVER commit .env to the repo — it is blocked by .gitignore
# ─────────────────────────────────────────────────────────────────

# OpenAI API key — used by SQUiD's pipeline and the GPT-4 baseline
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: pin the model version for reproducibility
# Record this string in Table 1 of the report template
OPENAI_MODEL=gpt-4
